    "5": {
      "type": "multiple_choice",
      "required": true,
      "valid_options": [
        "Summer (Hot)",
        "Winter (Cold)",
        "Spring (Mild)",
        "Fall/Autumn (Cool)",
        "Rainy",
        "Tropical"
      ]
    },
    "6": {
      "type": "multiple_choice",
      "required": true,
      "valid_options": [
        "Budget-friendly (Under $50)",
        "Moderate ($50-$150)",
        "Mid-range ($150-$300)",
        "Premium ($300-$500)",
        "Luxury ($500+)",
        "No specific budget"
      ]
    },
    "7": {
      "type": "multiple_choice",
      "required": true,
      "valid_options": [
        "Dresses/Skirts",
        "Pants/Jeans",
        "Shorts",
        "Traditional wear",
        "Mix of both casual and formal",
        "Comfortable loungewear"
      ]
    },
    "8": {
      "type": "text",
      "required": false,
      "min_length": 0,
      "max_length": 100
    },
    "9": {
      "type": "multiple_choice",
      "required": true,
      "valid_options": [
        "Minimal accessories",
        "Statement jewelry",
        "Scarves/Hats",
        "Bags/Purses",
        "Watches",
        "Sunglasses",
        "All of the above"
      ]
